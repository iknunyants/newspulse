TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here
DATABASE_PATH=data/newspulse.db
SCRAPE_INTERVAL_MINUTES=15
LOG_LEVEL=INFO
MAX_TOPICS_PER_USER=10
# Model for frequent relevance checks (yes/no classification, runs every 15 min)
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Model for keyword generation (higher quality, runs only when user adds a topic)
GEMINI_MODEL_KEYWORDS=gemini-3-flash-preview
